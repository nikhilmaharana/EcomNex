# Backend environment variables (copy to .env and fill with your values)
MONGO_URI=mongodb://localhost:27017/ecomnex
PORT=5000

# Contact email recipient (where site messages are sent)
CONTACT_EMAIL=nikhilmaharana10@gmail.com

# Email provider (either set EMAIL_SERVICE or EMAIL_HOST/EMAIL_PORT + credentials)
# Example for Gmail: EMAIL_SERVICE=Gmail
EMAIL_SERVICE=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# Used only by `npm run admin:create`
ADMIN_NAME=Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# JSON Web Token settings
JWT_SECRET=change-me-to-a-secure-secret
JWT_EXPIRES_IN=7d
